# .env.testing.example
# Copy this to .env.testing and fill in your local test database credentials.
# .env.testing is gitignored and must never be committed.

APP_ENV=testing
ENABLE_DEV_LOGIN=true

DB_HOST=127.0.0.1
DB_NAME=barepitch_test
DB_USER=root
DB_PASSWORD=

# Optional: set to a separate port if MySQL is not on the default
# DB_PORT=3306
