APP_ENV=local
APP_URL=http://localhost
APP_DEBUG=true

DB_HOST=127.0.0.1
DB_NAME=barepitch
DB_USER=barepitch
DB_PASSWORD=

MAIL_FROM_ADDRESS=no-reply@example.test
MAIL_FROM_NAME=BarePitch
MAIL_TRANSPORT=log

SESSION_IDLE_MINUTES=30
SESSION_ABSOLUTE_HOURS=12
LOGIN_TOKEN_MINUTES=15

RATE_LIMIT_LOGIN_PER_IP=10
RATE_LIMIT_LOGIN_PER_EMAIL=5
RATE_LIMIT_PUBLIC_LIVE_PER_IP=120

ENABLE_DEV_LOGIN=false
FORCE_HTTPS=false
ENABLE_HSTS=false

